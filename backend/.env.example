PORT=4000

# اتركها فارغة في التطوير للسماح لـ Flutter Web و Chrome بأي منفذ (localhost)
# مثال للإنتاج: https://app.example.com,https://admin.example.com
CORS_ORIGIN=
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/daytoday

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
ADMIN_JWT_EXPIRES_IN=1d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: path to Firebase service account JSON for push notifications
GOOGLE_APPLICATION_CREDENTIALS=

# OTP: in development, OTP is logged and may be returned in API response
OTP_EXPIRY_MINUTES=10

# Legacy email admin (seed:admin only) — لوحة التحكم تستخدم هاتف + سر عبر seed:demo
ADMIN_EMAIL=admin@daytoday.com
ADMIN_PASSWORD=ChangeMe123!

# Demo users: npm run seed:demo
# عميل: 01111989094 / 123456 — مسؤول: 01550490790 / 0000
